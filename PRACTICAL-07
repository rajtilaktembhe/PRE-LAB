<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Profile Page</title>

    <!-- Internal CSS -->
    <style>
        /* General Page Styling */
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(to right, #74ebd5, #ACB6E5);
        }

        /* Navigation Bar */
        nav {
            background-color: #333;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            margin: 0 15px;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
            color: #ffd700;
        }

        /* Profile Container */
        .container {
            width: 80%;
            margin: 30px auto;
            background-color: white;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0px 0px 10px rgba(0,0,0,0.2);
        }

        /* Profile Header */
        .header {
            text-align: center;
            border-bottom: 2px solid #ddd;
            padding-bottom: 10px;
        }

        .header h1 {
            color: #333;
        }

        /* Profile Image */
        .profile-img {
            display: block;
            margin: 15px auto;
            width: 150px;
            border-radius: 50%;
            border: 4px solid #333;
        }

        /* Sections */
        .section {
            margin-top: 20px;
        }

        .section h2 {
            color: #444;
            border-bottom: 2px solid #74ebd5;
            padding-bottom: 5px;
        }

        .section p {
            line-height: 1.6;
            color: #555;
        }

        /* Footer */
        footer {
            text-align: center;
            padding: 10px;
            background-color: #333;
            color: white;
            margin-top: 20px;
        }
    </style>
</head>

<body>

    <!-- Navigation Bar -->
    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Skills</a>
        <a href="#">Contact</a>
    </nav>

    <!-- Main Container -->
    <div class="container">

        <!-- Header -->
        <div class="header">
            <h1>Rajtilak Tembhe</h1>
            <p>Web Developer | Designer | Student</p>
        </div>

        
        <!-- About Section -->
        <div class="section">
            <h2>About Me</h2>
            <p>
                Hello! I am a passionate web developer who loves creating beautiful and functional websites.
                I enjoy learning new technologies and improving my skills.
            </p>
        </div>

        <!-- Skills Section -->
        <div class="section">
            <h2>Skills</h2>
            <p>HTML, CSS, JavaScript, Python</p>
        </div>

        <!-- Contact Section -->
        <div class="section">
            <h2>Contact</h2>
            <p>Email: rajtilakt.ml25@sbjit.edu.in</p>
        </div>

    </div>

    <!-- Footer -->
    <footer>
        <p>© 2026 My Profile Page</p>
    </footer>

</body>
</html>
